params {
    // Input/Output
    samplesheet  = "samplesheet.csv"
    output       = "results"

    // Reference URLs
    fasta_url    = "https://ftp.ncbi.nlm.nih.gov/genomes/all/GCF/000/001/735/GCF_000001735.4_TAIR10.1/GCF_000001735.4_TAIR10.1_genomic.fna.gz"
    gff_url      = "https://ftp.ncbi.nlm.nih.gov/genomes/all/GCF/000/001/735/GCF_000001735.4_TAIR10.1/GCF_000001735.4_TAIR10.1_genomic.gff.gz"

    // GenomicsDB
    athaliana_db = "athaliana_genomicsdb"
    bed = "data/intervals.bed"

    // PLINK QC
    maf          = 0.05
    geno         = 0.1
    mind         = 0.1

    // GWAS
    pheno_file   = "data/phenotypes.txt"
    p_thresh     = 1e-5

    // SnpEff
    snpeff_db    = "athalianaTair10"
}

process {
    cpus          = 4
    memory        = 8.GB 
    errorStrategy = "retry"
    maxRetries    = 3
}

docker {
    enabled = true
}

profiles {
    local {
        process.executor  = "local"
        process.container = "plant-variant-calling"
        docker.runOptions = "--pull=never"
    }

    awsbatch {
        process.executor  = "awsbatch"
        process.queue     = "plant-variant-calling-queue"
        process.container = "your-dockerhub-username/plant-variant-calling:latest"
        aws.region        = "us-east-1"
        aws.batch.cliPath = "/home/miniconda/bin/aws"
    }
}

trace {
    enabled = true
    file    = "pipeline_trace.txt"
}

report {
    enabled = true
    file    = "pipeline_report.html"
}

timeline {
    enabled = true
    file    = "pipeline_timeline.html"
}